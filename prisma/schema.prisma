datasource db {
  provider = "sqlite"
  
}

generator client {
  provider = "prisma-client-js"
}

model Team {
  id    Int    @id @default(autoincrement())
  name  String
  base  String
  drivers Driver[]
}

model Driver {
  id    Int    @id @default(autoincrement())
  name  String
  team  Team   @relation(fields: [teamId], references: [id])
  teamId Int
}
